# HTML snapshots — runtime artifacts, not source code
data/raw/*.html
data/challenges/*.html

# Keep empty data directories in git
!data/raw/.keep
!data/challenges/.keep

# sentinel.db IS committed — GitHub Actions needs it for change detection
# If you want to exclude it locally, comment the next line out
# data/sentinel.db

# Config — local only, never commit real config
config.toml
!config.example.toml

# Secrets
.env
.env.local

# Logs
*.log
logs/